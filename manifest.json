{
  "name": "SharingNE",
  "short_name": "SharingNE",
  "description": "Scambio file diretto tra i tuoi dispositivi sulla stessa Wi-Fi. Niente cloud.",
  "lang": "it",
  "start_url": "./?source=pwa",
  "scope": "./",
  "display": "standalone",
  "orientation": "any",
  "background_color": "#0c1420",
  "theme_color": "#0c1420",
  "icons": [
    { "src": "icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any" },
    { "src": "icon-512-maskable.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable" }
  ],
  "share_target": {
    "action": "share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        { "name": "files", "accept": ["*/*", "image/*", "video/*", "application/*", "text/*"] }
      ]
    }
  }
}
